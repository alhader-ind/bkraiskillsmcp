{
  "name": "agent-analysis-report",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "npm run sync-skills && vite build && esbuild server.ts --bundle --platform=node --outfile=dist/server.cjs",
    "sync-skills": "node scripts/sync-skills.js",
    "preview": "vite preview",
    "pages:deploy": "wrangler pages deploy dist",
    "deploy": "npm run sync-skills && npm run build && npm run pages:deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "express": "^5.2.1",
    "lucide-react": "^0.344.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.25",
    "@types/express": "^5.0.6",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.0.0-alpha.25",
    "tsx": "^4.21.0",
    "vite": "^5.1.4",
    "wrangler": "^4.86.0"
  }
}
