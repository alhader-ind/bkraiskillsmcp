{
  "name": "@my-org/agent-swarm",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "bin": {
    "agent-swarm": "bin/run-swarm.js"
  },
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "files": [
    "dist/lib",
    "bin"
  ],
  "scripts": {
    "dev": "npm run sync-skills && vite",
    "lint": "eslint .",
    "test": "vitest run",
    "start": "node dist/server.cjs",
    "build": "npm run sync-skills && vite build && esbuild src/worker.ts --bundle --platform=browser --format=esm --outfile=dist/_worker.js && esbuild server.ts --bundle --platform=node --outfile=dist/server.cjs && npm run build:lib",
    "build:lib": "vite build -c vite.lib.config.ts",
    "sync-skills": "tsx src/swarm/cli.ts sync --json",
    "preview": "vite preview",
    "pages:deploy": "npx wrangler pages deploy dist --project-name bkraiskillsmcp",
    "deploy": "node scripts/deploy.js",
    "test:pr": "tsx scripts/test-github-pr.ts"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "commander": "^14.0.3",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "lucide-react": "^0.344.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@eslint/js": "^10.0.1",
    "@hono/node-server": "^2.0.1",
    "@hono/vite-dev-server": "^0.25.3",
    "@tailwindcss/vite": "^4.0.0-alpha.25",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "tailwindcss": "^4.0.0-alpha.25",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.1.4",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  }
}
